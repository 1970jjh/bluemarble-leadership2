# ===========================================
# Firebase Configuration (Required)
# ===========================================
# Firebase 콘솔에서 프로젝트 설정 > 일반 > 내 앱에서 확인 가능
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ===========================================
# Google Apps Script Web App URL (Required for data storage)
# ===========================================
# Code.gs를 Google Apps Script에 배포한 후 웹앱 URL 입력
VITE_GAS_URL=your_google_apps_script_web_app_url

# ===========================================
# Gemini AI API Key (Required for AI evaluation)
# ===========================================
# Google AI Studio에서 발급: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key
